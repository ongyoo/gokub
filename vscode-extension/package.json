{
  "name": "gokub",
  "displayName": "GOKUB",
  "description": "Create and manage production-ready Go services with GOKUB.",
  "version": "0.1.0",
  "publisher": "roomkub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ongyoo/gokub.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Programming Languages", "Other"],
  "keywords": ["go", "golang", "scaffold", "mcp", "codex", "claude"],
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      { "command": "gokub.open", "title": "GOKUB: Open Command Center" },
      { "command": "gokub.newProject", "title": "GOKUB: New Project" },
      { "command": "gokub.addTemplate", "title": "GOKUB: Add Custom Template" },
      { "command": "gokub.installTemplate", "title": "GOKUB: Install Community Template" },
      { "command": "gokub.searchTemplates", "title": "GOKUB: Search Community Templates" },
      { "command": "gokub.listTemplates", "title": "GOKUB: List Custom Templates" },
      { "command": "gokub.addFeature", "title": "GOKUB: Add Feature" },
      { "command": "gokub.generateModel", "title": "GOKUB: Generate Model from JSON" },
      { "command": "gokub.status", "title": "GOKUB: Project Status" },
      { "command": "gokub.doctor", "title": "GOKUB: Run Doctor" },
      { "command": "gokub.score", "title": "GOKUB: Project Score" },
      { "command": "gokub.qualityGate", "title": "GOKUB: Run Quality Gate" },
      { "command": "gokub.graph", "title": "GOKUB: Dependency Graph" },
      { "command": "gokub.architectureCheck", "title": "GOKUB: Run Architecture Check" },
      { "command": "gokub.upgrade", "title": "GOKUB: Upgrade Project" },
      { "command": "gokub.updateCLI", "title": "GOKUB: Update CLI" },
      { "command": "gokub.openMCPConfig", "title": "GOKUB: Open MCP Configuration" },
      { "command": "gokub.installSkills", "title": "GOKUB: Install Agent Skills" },
      { "command": "gokub.createPlugin", "title": "GOKUB: Create Plugin" },
      { "command": "gokub.installPlugin", "title": "GOKUB: Install Plugin" },
      { "command": "gokub.packPlugin", "title": "GOKUB: Package Plugin" },
      { "command": "gokub.listPlugins", "title": "GOKUB: List Plugins" },
      { "command": "gokub.uninstall", "title": "GOKUB: Uninstall CLI" }
    ],
    "configuration": {
      "title": "GOKUB",
      "properties": {
        "gokub.executablePath": {
          "type": "string",
          "default": "gokub",
          "description": "Path to the GOKUB CLI executable."
        }
      }
    }
  },
  "scripts": {
    "test": "node --check extension.js && node test-extension.js",
    "package": "npx @vscode/vsce package --out ../dist/gokub-vscode.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  }
}
