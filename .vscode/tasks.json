{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "GOKUB: Test",
      "type": "shell",
      "command": "go test ./...",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": "$go"
    },
    {
      "label": "GOKUB: Build",
      "type": "shell",
      "command": "go build ./...",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$go"
    }
  ]
}
