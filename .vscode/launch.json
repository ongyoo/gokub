{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "GOKUB CLI: Debug",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/gokub",
      "args": ["help"],
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "GOKUB CLI: Test current package",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}"
    }
  ]
}
